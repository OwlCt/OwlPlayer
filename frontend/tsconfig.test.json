{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.prop.test.ts",
    "src/**/*.prop.test.tsx",
    "src/test/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
