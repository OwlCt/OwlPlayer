{
  "name": "streaming-player-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && node scripts/generate-sw-manifest.js",
    "typecheck": "tsc -p tsconfig.json",
    "build:typecheck": "npm run typecheck && vite build && node scripts/generate-sw-manifest.js",
    "preview": "vite preview",
    "lint": "eslint src vite.config.ts --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "axios": "^1.6.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "hls.js": "^1.6.15",
    "idb": "^8.0.3",
    "opencc-js": "^1.0.5",
    "overlayscrollbars": "^2.13.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^3.4.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.3.0",
    "globals": "^17.5.0",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.0.0",
    "vitest": "^4.0.14"
  }
}
