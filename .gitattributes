# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF line endings
*.sh text eol=lf

# Windows scripts should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Go files should use LF
*.go text eol=lf

# TypeScript/JavaScript files should use LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# Config files should use LF
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Documentation
*.md text eol=lf

# Dockerfile should use LF
Dockerfile text eol=lf
*.dockerfile text eol=lf
